# 1. Create a project at https://supabase.com/dashboard
# 2. Project Settings -> API -> copy "Project URL" and "anon public" key below
# 3. Rename this file to .env.local
# 4. Never commit .env.local or push the anon key to a public repo (see
#    supabase/schema.sql for the RLS tradeoff note — this app assumes
#    private, single-user use only).

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
